---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Prose from '../components/Prose.astro';
import { breadcrumbList } from '../lib/jsonld';
import { SITE } from '../config/site';

const page = await getEntry('pages', 'contact');
if (!page) throw new Error('Missing pages/contact.md content entry');
const { Content } = await render(page);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Contact', href: '/contact/' },
];
---

<BaseLayout
  title="Contact"
  description={page.data.description}
  path="/contact/"
  jsonLd={[breadcrumbList(crumbs)]}
>
  <div class="container">
    <Breadcrumbs crumbs={crumbs} />
    <div class="contact">
      <h1>{page.data.title}</h1>
      <Prose><Content /></Prose>
      <p class="contact-email">
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
      <p class="contact-note">
        Only confirmed, current details appear here; other channels will be added as Becca confirms
        them.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .contact {
    max-width: var(--width-content);
    margin-inline: auto;
    padding-block: var(--space-lg) var(--space-3xl);
  }

  .contact-email {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-block: var(--space-lg) var(--space-xs);
    overflow-wrap: anywhere;
  }

  .contact-note {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
</style>
