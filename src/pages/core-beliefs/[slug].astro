---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Prose from '../../components/Prose.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { breadcrumbList } from '../../lib/jsonld';

export async function getStaticPaths() {
  const beliefs = await getCollection('beliefs');
  return beliefs.map((belief) => ({ params: { slug: belief.id }, props: { belief } }));
}

interface Props {
  belief: CollectionEntry<'beliefs'>;
}

const { belief } = Astro.props;
const { Content } = await render(belief);

const allBeliefs = (await getCollection('beliefs')).sort((a, b) => a.data.order - b.data.order);
const prevBelief = allBeliefs.find((entry) => entry.data.order === belief.data.order - 1);
const nextBelief = allBeliefs.find((entry) => entry.data.order === belief.data.order + 1);

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'The Three Core Beliefs', href: '/core-beliefs/' },
  { label: belief.data.title, href: `/core-beliefs/${belief.id}/` },
];
---

<BaseLayout
  title={belief.data.title}
  description={belief.data.description}
  path={`/core-beliefs/${belief.id}/`}
  jsonLd={[breadcrumbList(crumbs)]}
>
  <div class="container">
    <Breadcrumbs crumbs={crumbs} />
    <article class="belief">
      <p class="belief-kicker">Core belief {belief.data.order} of 3</p>
      <h1>{belief.data.title}</h1>
      <p class="belief-essence">{belief.data.essence}</p>
      <Prose><Content /></Prose>

      {
        belief.data.awaitingContent && (
          <div class="belief-awaiting">
            <SectionDivider />
            <p>
              Becca is writing the full teaching for this belief, and her own words will appear here
              as they arrive. In the meantime, the
              <a href="/8-bridging-keys/">8 Bridging Keys</a> show the practice this belief sits
              beneath.
            </p>
          </div>
        )
      }
    </article>

    <nav class="belief-pagination no-print" aria-label="Core belief navigation">
      {
        prevBelief ? (
          <a href={`/core-beliefs/${prevBelief.id}/`} rel="prev">
            Previous: {prevBelief.data.title}
          </a>
        ) : (
          <span />
        )
      }
      {
        nextBelief ? (
          <a href={`/core-beliefs/${nextBelief.id}/`} rel="next">
            Next: {nextBelief.data.title}
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </div>
</BaseLayout>

<style>
  .belief {
    max-width: var(--width-content);
    margin-inline: auto;
    padding-block: var(--space-lg) var(--space-xl);
  }

  .belief-kicker {
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-block-end: var(--space-xs);
  }

  .belief-essence {
    font-size: var(--text-md);
    color: var(--color-ink-muted);
    margin-block-end: var(--space-lg);
  }

  .belief-awaiting {
    margin-block-start: var(--space-xl);
    padding: var(--space-lg);
    border: 1px dashed var(--color-line);
    border-radius: var(--radius-md);
    background: var(--color-surface-alt);
    text-align: center;
  }

  .belief-awaiting p {
    margin: var(--space-md) 0 0;
    color: var(--color-ink-muted);
  }

  .belief-pagination {
    max-width: var(--width-content);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    border-top: 1px solid var(--color-line);
    padding-block: var(--space-lg) var(--space-xl);
  }

  .belief-pagination a {
    min-height: var(--tap-min);
    display: inline-flex;
    align-items: center;
  }
</style>
