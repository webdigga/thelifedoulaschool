---
/**
 * "Print this key" affordance (brief §6): key pages are teaching handouts.
 */
---

<button type="button" class="print-button no-print" data-print>
  <svg viewBox="0 0 24 24" width="18" fill="none" aria-hidden="true">
    <path
      d="M7 8V4h10v4M7 16H5a2 2 0 0 1-2-2v-4a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2m-10-2h10v6H7v-6z"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
  Print this key
</button>

<script>
  // Justified client-side JS (see CLAUDE.md): window.print() has no
  // HTML-only equivalent, and the button is progressive (hidden in print).
  for (const button of document.querySelectorAll('[data-print]')) {
    button.addEventListener('click', () => window.print());
  }
</script>

<style>
  .print-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    min-height: var(--tap-min);
    padding: var(--space-xs) var(--space-md);
    background: none;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    color: var(--color-brand);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: border-color var(--motion-quick) var(--ease-soft);
  }

  .print-button:hover {
    border-color: var(--color-brand);
  }
</style>
