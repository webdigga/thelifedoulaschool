---
/**
 * Site header: interim text wordmark (open question 8: replace with the
 * agreed logo when it exists) plus primary navigation from the brief's IA.
 */
const NAV = [
  { label: 'Home', href: '/' },
  { label: 'The 8 Bridging Keys', href: '/8-bridging-keys/' },
  { label: 'Protocols', href: '/protocols/' },
  { label: 'Core Beliefs', href: '/core-beliefs/' },
  { label: 'About', href: '/about/' },
  { label: 'Blog', href: '/blogs/' },
  { label: 'Contact', href: '/contact/' },
] as const;

const currentPath = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header no-print">
  <div class="container header-inner">
    <a class="wordmark" href="/">The Life Doula School</a>
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      data-nav-toggle
    >
      <span class="visually-hidden">Menu</span>
      <span class="nav-toggle-bar" aria-hidden="true"></span>
    </button>
    <nav id="primary-nav" class="primary-nav" aria-label="Primary" data-nav>
      <ul>
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  // Justified client-side JS (see CLAUDE.md): an accessible disclosure menu on
  // small screens needs aria-expanded state, which CSS alone cannot manage.
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const nav = document.querySelector<HTMLElement>('[data-nav]');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      nav.classList.toggle('is-open', !open);
    });
  }
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-line);
    background: var(--color-surface);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    flex-wrap: wrap;
    padding-block: var(--space-md);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-ink);
    text-decoration: none;
    line-height: var(--leading-tight);
    min-height: var(--tap-min);
    display: inline-flex;
    align-items: center;
  }

  .nav-toggle {
    display: none;
    min-width: var(--tap-min);
    min-height: var(--tap-min);
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }

  .nav-toggle-bar {
    display: block;
    width: 1.25rem;
    height: 2px;
    background: var(--color-ink);
    position: relative;
  }

  .nav-toggle-bar::before,
  .nav-toggle-bar::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    height: 2px;
    background: var(--color-ink);
  }

  .nav-toggle-bar::before {
    top: -6px;
  }

  .nav-toggle-bar::after {
    top: 6px;
  }

  .primary-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .primary-nav a {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-min);
    padding: var(--space-2xs) var(--space-sm);
    color: var(--color-ink);
    text-decoration: none;
    font-size: var(--text-sm);
    border-radius: var(--radius-sm);
  }

  .primary-nav a:hover {
    color: var(--color-brand-strong);
    background: var(--color-surface-alt);
  }

  .primary-nav a[aria-current='page'] {
    color: var(--color-brand);
  }

  /* Square-ended underline: an ::after bar, so the link's rounded corners
     (kept for the hover background) cannot curve the underline's ends. */
  .primary-nav a[aria-current='page']::after {
    content: '';
    position: absolute;
    inset-inline: var(--space-sm);
    inset-block-end: 0;
    block-size: 2px;
    background: var(--color-glow);
  }

  @media (width <= 47.9rem) {
    .nav-toggle {
      display: inline-flex;
    }

    .primary-nav {
      display: none;
      width: 100%;
    }

    .primary-nav.is-open {
      display: block;
    }

    .primary-nav ul {
      flex-direction: column;
      gap: 0;
      padding-block: var(--space-xs) var(--space-md);
    }

    .primary-nav a {
      width: 100%;
      padding: var(--space-sm);
      font-size: var(--text-base);
    }
  }
</style>
