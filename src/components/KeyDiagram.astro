---
/**
 * Exemplar key diagram (brief §6, open question 7): the pattern every real
 * diagram will follow once the client's SmartArt specifications arrive. Her
 * SmartArt is treated as the spec for wording, structure, and colour intent;
 * this native SVG renders in site tokens and site typography, and prints
 * crisply. Wording below is placeholder until her diagrams are supplied.
 *
 * Layout: the key at the centre, its 7 ways arranged around it.
 */
interface Way {
  title: string;
}

interface Props {
  keyTitle: string;
  ways: readonly Way[];
}

const { keyTitle, ways } = Astro.props;

const labels =
  ways.length === 7
    ? ways.map((way) => way.title)
    : ['One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven'];

const CX = 320;
const CY = 250;
const ORBIT = 165;
const NODE_R = 44;

const nodes = labels.map((label, index) => {
  const angle = -Math.PI / 2 + (index * 2 * Math.PI) / 7;
  return {
    label,
    number: index + 1,
    x: CX + ORBIT * Math.cos(angle),
    y: CY + ORBIT * Math.sin(angle),
  };
});
---

<figure class="key-diagram">
  <svg
    viewBox="0 0 640 500"
    role="img"
    aria-label={`Diagram of the ${keyTitle} key surrounded by its seven ways: ${labels.join(', ')}`}
  >
    {nodes.map((node) => <line class="spoke" x1={CX} y1={CY} x2={node.x} y2={node.y} />)}
    <circle class="hub" cx={CX} cy={CY} r="78"></circle>
    <text class="hub-label" x={CX} y={CY + 8} text-anchor="middle">{keyTitle}</text>
    {
      nodes.map((node) => (
        <g>
          <circle class="node" cx={node.x} cy={node.y} r={NODE_R} />
          <text class="node-number" x={node.x} y={node.y - 6} text-anchor="middle">
            {node.number}
          </text>
          <text class="node-label" x={node.x} y={node.y + 16} text-anchor="middle">
            {node.label}
          </text>
        </g>
      ))
    }
  </svg>
  <figcaption>
    The {keyTitle} key and its 7 ways. Exemplar layout; Becca's own diagram wording will replace these
    labels as it arrives.
  </figcaption>
</figure>

<style>
  .key-diagram {
    margin: 0;
  }

  .key-diagram svg {
    display: block;
    width: 100%;
    max-width: 40rem;
    margin-inline: auto;
  }

  .spoke {
    stroke: var(--color-line);
    stroke-width: 1.5;
  }

  .hub {
    fill: var(--color-brand);
  }

  .hub-label {
    font-family: var(--font-display);
    font-size: 1.5rem;
    fill: var(--color-brand-contrast);
  }

  .node {
    fill: var(--color-surface);
    stroke: var(--color-glow);
    stroke-width: 1.5;
  }

  .node-number {
    font-family: var(--font-display);
    font-size: 1rem;
    fill: var(--color-accent);
  }

  .node-label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    fill: var(--color-ink);
  }

  .key-diagram figcaption {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-block-start: var(--space-sm);
  }
</style>
