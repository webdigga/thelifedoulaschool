---
/**
 * One testimonial quote. The three existing quotes speak to Becca's
 * character and survive the pivot (pending client review).
 */
interface Props {
  heading: string;
  quote: string;
  name: string;
}

const { heading, quote, name } = Astro.props;
---

<figure class="testimonial">
  <p class="testimonial-heading">{heading}</p>
  <blockquote>
    <p>{quote}</p>
  </blockquote>
  <figcaption>{name}</figcaption>
</figure>

<style>
  .testimonial {
    margin: 0;
    padding: var(--space-lg);
    border-inline-start: 3px solid var(--color-glow);
    background: var(--color-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .testimonial-heading {
    font-family: var(--font-display);
    font-size: var(--text-md);
    margin-block-end: var(--space-sm);
  }

  .testimonial blockquote {
    margin: 0 0 var(--space-sm);
  }

  .testimonial blockquote p {
    margin: 0;
    color: var(--color-ink-muted);
  }

  .testimonial figcaption {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-family: var(--font-display);
  }
</style>
