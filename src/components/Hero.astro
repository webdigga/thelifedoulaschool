---
/**
 * Homepage hero, version three: pure typography on a deep brand panel.
 * After two rejected graphic treatments the hero now carries the thesis with
 * type alone: night-sky indigo above, the warm page (earth) below, echoing
 * the footer so the page is bookended by the dark side of the palette.
 * No SVG, no gradients, nothing that can degrade.
 */
interface Props {
  title: string;
  strapline: string;
  subline: string;
}

const { title, strapline, subline } = Astro.props;

// A sparse, hand-placed star field for the hero's empty corners. Decorative
// only; positions deliberately avoid the central text column. Dots use
// currentColor so a styling failure degrades to the text colour, never black.
const STARS: [number, number, number, number][] = [
  [60, 60, 2, 0.7],
  [150, 120, 1.4, 0.5],
  [240, 50, 1.2, 0.4],
  [90, 210, 1.6, 0.45],
  [40, 330, 1.3, 0.35],
  [200, 300, 1.1, 0.3],
  [320, 90, 1.5, 0.5],
  [420, 40, 1.2, 0.4],
  [1140, 70, 2, 0.7],
  [1050, 140, 1.4, 0.5],
  [960, 55, 1.2, 0.4],
  [1110, 230, 1.6, 0.45],
  [1160, 340, 1.3, 0.35],
  [1000, 310, 1.1, 0.3],
  [880, 50, 1.5, 0.5],
  [760, 35, 1.2, 0.4],
  [180, 390, 1.2, 0.3],
  [1020, 390, 1.2, 0.3],
];
---

<section class="hero">
  <svg
    class="hero-stars"
    viewBox="0 0 1200 420"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    {STARS.map(([x, y, r, o]) => <circle cx={x} cy={y} r={r} opacity={o} fill="currentColor" />)}
  </svg>
  <div class="container hero-content">
    <p class="hero-strapline">{strapline}</p>
    <h1 class="hero-title">{title}</h1>
    <p class="hero-subline">{subline}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-brand);
    overflow: hidden;
  }

  .hero-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-glow);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding-block: var(--space-3xl);
  }

  .hero-strapline {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-contrast);
    opacity: 0.75;
    margin-block-end: var(--space-lg);
  }

  .hero-title {
    font-size: var(--text-hero);
    color: var(--color-brand-contrast);
    margin-block-end: var(--space-lg);
  }

  .hero-subline {
    font-size: var(--text-lg);
    color: var(--color-brand-contrast);
    opacity: 0.85;
    max-width: 44ch;
    margin-inline: auto;
    text-wrap: balance;
  }
</style>
