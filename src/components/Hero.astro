---
/**
 * Homepage hero: the thesis. "Bridging Heaven and Earth" set over the motif,
 * with the strapline and subline. One considered entrance animation, disabled
 * under prefers-reduced-motion by the global rule.
 */
import BridgeMotif from './BridgeMotif.astro';

interface Props {
  title: string;
  strapline: string;
  subline: string;
}

const { title, strapline, subline } = Astro.props;
---

<section class="hero">
  <div class="hero-backdrop" aria-hidden="true">
    <BridgeMotif variant="hero" />
  </div>
  <div class="container hero-content">
    <p class="hero-strapline">{strapline}</p>
    <h1 class="hero-title">{title}</h1>
    <p class="hero-subline">{subline}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-line);
    background: var(--gradient-sky), var(--color-surface);
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding-block: var(--space-3xl);
    animation: hero-rise var(--motion-gentle) var(--ease-soft) both;
  }

  /* On small screens the wrapped subline reaches further down the motif, so
     extra bottom padding keeps the text clear of the horizon line. */
  @media (width <= 48rem) {
    .hero-content {
      padding-block: var(--space-2xl) calc(var(--space-3xl) + var(--space-2xl));
    }
  }

  .hero-strapline {
    font-family: var(--font-display);
    font-size: var(--text-md);
    color: var(--color-accent);
    margin-block-end: var(--space-md);
  }

  .hero-title {
    font-size: var(--text-hero);
    margin-block-end: var(--space-lg);
  }

  .hero-subline {
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    max-width: 44ch;
    margin-inline: auto;
    text-wrap: balance;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(0.75rem);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
