---
/**
 * The site's one signature visual, version two: "the light field".
 * After feedback that no line work suits the hero, this is built entirely
 * from soft filled shapes: a dawn glow rising from the base (heaven's light)
 * and two gentle ground swells (earth), meeting behind the content. No
 * strokes anywhere. Still decorative, token-coloured, isolated in this one
 * component, and deletable in one place.
 *
 * variant "hero": full-bleed backdrop. variant "divider": a small sun disc
 * with a halo, used as a section ornament.
 */
interface Props {
  variant?: 'hero' | 'divider';
}

const { variant = 'hero' } = Astro.props;
---

{
  variant === 'hero' ? (
    <svg
      class="motif motif-hero"
      viewBox="0 0 1200 420"
      preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
    >
      <defs>
        <radialGradient id="motif-dawn" cx="50%" cy="100%" r="80%">
          <stop offset="0%" class="stop-glow" stop-opacity="0.42" />
          <stop offset="45%" class="stop-glow" stop-opacity="0.16" />
          <stop offset="100%" class="stop-glow" stop-opacity="0" />
        </radialGradient>
      </defs>
      <rect x="0" y="0" width="1200" height="420" fill="url(#motif-dawn)" />
      <path class="swell swell-far" d="M0 420 L0 370 Q 300 328 620 354 T 1200 344 L1200 420 Z" />
      <path class="swell swell-near" d="M0 420 L0 400 Q 430 354 780 388 T 1200 394 L1200 420 Z" />
    </svg>
  ) : (
    <svg class="motif motif-divider" viewBox="0 0 120 32" aria-hidden="true">
      <defs>
        <radialGradient id="motif-divider-halo" cx="50%" cy="50%" r="50%">
          <stop offset="0%" class="stop-glow" stop-opacity="0.5" />
          <stop offset="100%" class="stop-glow" stop-opacity="0" />
        </radialGradient>
      </defs>
      <ellipse cx="60" cy="16" rx="56" ry="14" fill="url(#motif-divider-halo)" />
      <circle class="divider-sun" cx="60" cy="16" r="4.5" />
    </svg>
  )
}

<style>
  .motif {
    display: block;
    pointer-events: none;
  }

  .motif-hero {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .motif-divider {
    width: 7.5rem;
    margin-inline: auto;
  }

  .stop-glow {
    stop-color: var(--color-glow);
  }

  .swell-far {
    fill: var(--color-brand);
    opacity: 0.08;
  }

  .swell-near {
    fill: var(--color-glow);
    opacity: 0.14;
  }

  .divider-sun {
    fill: var(--color-glow);
  }
</style>
