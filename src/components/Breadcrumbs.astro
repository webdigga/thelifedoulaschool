---
/**
 * Visible breadcrumb trail for nested pages. The matching BreadcrumbList
 * JSON-LD is emitted by the page via breadcrumbList() from lib/jsonld so the
 * visible trail and the structured data always share one source of truth.
 */
import type { Crumb } from '../lib/jsonld';

interface Props {
  crumbs: readonly Crumb[];
}

const { crumbs } = Astro.props;
---

<nav class="breadcrumbs no-print" aria-label="Breadcrumb">
  <ol>
    {
      crumbs.map((crumb, index) => (
        <li>
          {index < crumbs.length - 1 ? (
            <a href={crumb.href}>{crumb.label}</a>
          ) : (
            <span aria-current="page">{crumb.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    padding-block: var(--space-md);
  }

  .breadcrumbs ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }

  .breadcrumbs li + li::before {
    content: '/';
    margin-inline: var(--space-2xs);
    color: var(--color-line);
  }

  .breadcrumbs a {
    color: var(--color-ink-muted);
  }

  .breadcrumbs a:hover {
    color: var(--color-brand);
  }

  .breadcrumbs span[aria-current] {
    color: var(--color-ink);
  }
</style>
